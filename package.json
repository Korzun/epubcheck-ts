{
  "name": "@korzun/epubcheck-ts",
  "version": "0.1.0-beta.0",
  "description": "A TypeScript-native EPUB validator (library).",
  "type": "module",
  "license": "BSD-3-Clause",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "ATTRIBUTION.md"
  ],
  "scripts": {
    "build": "tsdown",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "css-tree": "^3.2.1",
    "fflate": "0.8.3",
    "saxes": "6.0.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "eslint": "10.6.0",
    "tsdown": "0.22.3",
    "typescript": "5.7.2",
    "typescript-eslint": "8.62.0",
    "vitest": "4.1.9"
  }
}
